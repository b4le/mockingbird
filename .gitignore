# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent scratch (Claude Code worktrees, prefetch cache, session artefacts)
/.claude/
/local-state/
/.playwright-mcp/
/.full-review/

# local npm cache (workaround for root-owned ~/.npm)
/.npm-cache/

# local export data (generated by atticus-finch export_mockingbird.py)
/data/local/

# audio-migration scratch
# - scripts/.venv/, scripts/__pycache__/ from running migrate_audio_to_gcs.py
# - tmp/ for the CORS-config scratch file used in the GCS bucket runbook
# The OAuth token cache and migration manifest both live under
# /local-state/ (already ignored above).
/scripts/.venv/
/scripts/__pycache__/
/tmp/
