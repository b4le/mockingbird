# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent scratch (Claude Code worktrees, prefetch cache, session artefacts)
/.claude/
/local-state/
/.playwright-mcp/

# local npm cache (workaround for root-owned ~/.npm)
/.npm-cache/

# local export data (generated by atticus-finch export_mockingbird.py)
/data/local/

# audio migration manifest — committing it to a public repo defeats the
# random-suffix obscurity goal for the GCS bucket name (see
# docs/audio-hosting/gcs-bucket-setup.md "Notes / decision rationale").
/data/scout/audio-migration-manifest.json
scripts/.venv/
/tmp/
__pycache__/
